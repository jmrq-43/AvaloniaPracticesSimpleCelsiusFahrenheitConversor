<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="450"
        x:Class="AvaloniaApplication2.MainWindow"
        Title="GetStartedApp"
        Width="400"
        Height="450">
    <StackPanel>
        <Border Margin="5"
                CornerRadius="10"
                Background="LightBlue">
            <TextBlock Margin="5"
                       FontSize="24"
                       HorizontalAlignment="Center"
                       Text="Temperature Converter" />
        </Border>
        <Grid ShowGridLines="False"
              ColumnDefinitions="120, 100"
              RowDefinitions="Auto, Auto">
            <TextBlock Grid.Row="0" Grid.Column="0">Celsius</TextBlock>
            <TextBox 
                TextChanged="Celsius_TextChanged"
                Grid.Column="1" Margin="0 5" Text="0" Name="Celsius"/>
            <TextBlock Grid.Row="1" Grid.Column="0">Fahrenheit</TextBlock>
            <TextBox IsReadOnly="True" Grid.Row="1" Grid.Column="1" Margin="0 5" Text="0" Name="Fahrenheit" />
            
        </Grid>
    </StackPanel>
</Window>